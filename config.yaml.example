port: "8080"
storage_type: "local" # options: "local", "gcs", "drive"
zip_dir: "./publish"   # for "local"
cache_dir: "./cache"   # for cloud caching

gcs:
  bucket: "my-zips-bucket"
  credentials_file: "path/to/gcs-service-account.json"

drive:
  folder_id: "1abc2def3ghi..."
  credentials_file: "path/to/drive-service-account.json"

auth:
  enabled: true
  client_id: "YOUR_GOOGLE_CLIENT_ID"
  client_secret: "YOUR_GOOGLE_CLIENT_SECRET"
  redirect_url: "http://localhost:8080/callback"
  allowed_users:
    - "*@company.com"
    - "user@thirdparty.com"
  session_key: "super-secret-session-key"
  upload_token: "your-secret-upload-token" # for Bearer authentication
